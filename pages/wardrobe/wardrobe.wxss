/* ========================================
   衣橱页样式
   ======================================== */

.page-wardrobe {
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding-top: 48rpx;
  background-color: rgba(249, 250, 251, 0.5);
}

/* Toggle */
.toggle-section {
  padding: 0 48rpx;
  margin-bottom: 32rpx;
}

.toggle-switch {
  display: flex;
  background-color: #f3f4f6;
  padding: 4rpx;
  border-radius: 24rpx;
}

.toggle-item {
  flex: 1;
  padding: 16rpx 0;
  border-radius: 20rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #6b7280;
  display: flex;
  align-items: center;
  justify-content: center;
}

.toggle-active {
  background-color: #ffffff;
  color: #111827;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.05);
}

.wishlist-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #ef4444;
  border-radius: 50%;
  margin-left: 12rpx;
}

/* Search */
.search-section {
  padding: 0 48rpx;
  margin-bottom: 32rpx;
  display: flex;
}

.search-box {
  flex: 1;
  position: relative;
  margin-right: 24rpx;
}

.search-icon-text {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  z-index: 1;
}

.search-input {
  width: 100%;
  background-color: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 24rpx;
  padding: 24rpx 24rpx 24rpx 80rpx;
  font-size: 30rpx;
  line-height: 1.5;
  min-height: 88rpx;
  box-sizing: border-box;
}

.filter-btn {
  width: 80rpx;
  height: 80rpx;
  background-color: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #6b7280;
}

/* Category Scroll */
.category-scroll {
  padding-left: 48rpx;
  margin-bottom: 32rpx;
  white-space: nowrap;
  width: 100%;
}

.category-list {
  display: flex;
  padding-right: 48rpx;
}

.category-chip {
  padding: 12rpx 24rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 500;
  white-space: nowrap;
  background-color: #ffffff;
  color: #6b7280;
  border: 1px solid #f3f4f6;
  margin-right: 16rpx;
}

.chip-active {
  background-color: #111827;
  color: #ffffff;
}

/* Items Grid */
.items-scroll {
  flex: 1;
  overflow-y: auto;
}

.items-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 48rpx 160rpx;
}

/* Add Card */
.add-card {
  width: calc(50% - 16rpx);
  margin: 0 16rpx 32rpx 0;
  border: 2px dashed;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 400rpx;
}

.add-owned {
  border-color: #e5e7eb;
  color: #9ca3af;
}

.add-wishlist {
  border-color: #ddd6fe;
  background-color: rgba(245, 243, 255, 0.3);
}

.add-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.add-circle-wishlist {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.05);
}

.add-plus {
  font-size: 48rpx;
  color: #9ca3af;
}

.add-plus-wishlist {
  font-size: 48rpx;
}

.add-text {
  font-size: 24rpx;
  font-weight: 500;
}

.add-text-wishlist {
  font-size: 24rpx;
  font-weight: 700;
  color: #9333ea;
}

.add-sub-wishlist {
  font-size: 20rpx;
  color: #c084fc;
  margin-top: 8rpx;
}

/* Item Card */
.item-card {
  width: calc(50% - 16rpx);
  margin: 0 16rpx 32rpx 0;
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  background-color: #ffffff;
  height: 400rpx;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.05);
}

.item-image {
  width: 100%;
  height: 100%;
}

.item-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background-color: rgba(255, 255, 255, 0.9);
  padding: 4rpx 16rpx;
  border-radius: 9999rpx;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.05);
}

.item-badge text {
  font-size: 20rpx;
  font-weight: 500;
  color: #4b5563;
}

.item-actions {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx;
  color: #ffffff;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-tag {
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-heart {
  font-size: 32rpx;
}

/* ===== 识图确认弹窗 ===== */
.recognize-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.recognize-modal {
  width: 100%;
  max-width: 600rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
  box-sizing: border-box;
}

.recognize-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.recognize-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.recognize-close {
  font-size: 40rpx;
  color: #9ca3af;
  padding: 0 12rpx;
}

.recognize-img {
  width: 100%;
  height: 400rpx;
  background: #f9fafb;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.recognize-form {
  margin-bottom: 24rpx;
}

.recognize-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.recognize-label {
  width: 100rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #6b7280;
  flex-shrink: 0;
}

.recognize-input,
.recognize-picker {
  flex: 1;
  background: #f9fafb;
  border: 1px solid #e5e7eb;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  min-height: 64rpx;
  box-sizing: border-box;
  line-height: 1.4;
}

.recognize-picker {
  color: #111827;
}

.recognize-actions {
  display: flex;
  gap: 20rpx;
}

.recognize-btn {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 24rpx;
  padding: 20rpx 0;
  border: none;
  margin: 0;
}

.recognize-btn.cancel {
  background: #f3f4f6;
  color: #6b7280;
}

.recognize-btn.confirm {
  background: #111827;
  color: #ffffff;
}

.recognize-btn::after {
  border: none;
}

/* ========================================
   试衣间样式
   ======================================== */

.page-tryon {
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 48rpx 48rpx 0;
  position: relative;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 16rpx;
  display: block;
}

/* Mode Switcher */
.mode-switch {
  display: flex;
  background-color: #f3f4f6;
  padding: 4rpx;
  border-radius: 24rpx;
  margin-bottom: 48rpx;
  flex-shrink: 0;
}

.mode-item {
  flex: 1;
  padding: 16rpx 0;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #6b7280;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mode-emoji {
  margin-right: 4rpx;
  font-size: 24rpx;
}

.mode-active {
  background-color: #ffffff;
  color: #111827;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.05);
}

.mode-active.accent {
  color: #9333ea;
}

/* Config Body */
.config-body {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 192rpx;
}

.section { margin-bottom: 48rpx; }

.section-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #374151;
  margin-bottom: 24rpx;
  display: block;
}

.occasion-grid {
  display: flex;
  flex-wrap: wrap;
}

.occasion-item {
  width: calc(50% - 12rpx);
  margin: 0 12rpx 24rpx 0;
  padding: 24rpx 32rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  background-color: #ffffff;
  color: #4b5563;
  border: 1px solid #e5e7eb;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
}

.occasion-active {
  background-color: #111827;
  color: #ffffff;
  box-shadow: 0 20rpx 30rpx -10rpx rgba(0,0,0,0.2);
  transform: scale(1.02);
}

.occasion-check { font-size: 28rpx; }

/* Info Cards */
.info-card {
  padding: 32rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: flex-start;
}

.info-card.blue {
  background-color: #eff6ff;
  border: 1px solid #dbeafe;
}

.info-card.purple {
  background-color: #faf5ff;
  border: 1px solid #f3e8ff;
}

.info-emoji {
  font-size: 36rpx;
  margin-right: 16rpx;
  margin-top: 4rpx;
}

.info-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e40af;
  display: block;
}

.info-desc {
  font-size: 24rpx;
  color: #2563eb;
  margin-top: 8rpx;
  line-height: 1.625;
  display: block;
}

.info-title-purple {
  font-size: 28rpx;
  font-weight: 700;
  color: #581c87;
  display: block;
}

.info-desc-purple {
  font-size: 24rpx;
  color: #7e22ce;
  margin-top: 8rpx;
  display: block;
}

/* Custom Items Grid */
.items-grid-3 {
  display: flex;
  flex-wrap: wrap;
  margin-top: 32rpx;
}

.custom-item {
  width: calc(33.33% - 16rpx);
  margin: 0 16rpx 24rpx 0;
  position: relative;
  height: 280rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.custom-item-img {
  width: 100%;
  height: 100%;
}

.custom-selected {
  border: 4rpx solid #22c55e;
}

.custom-check-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background-color: #22c55e;
  border-radius: 50%;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
  z-index: 10;
  color: #ffffff;
  font-size: 24rpx;
}

/* Pre-Buy */
.sub-tabs {
  display: flex;
  border-bottom: 1px solid #f3f4f6;
  padding-bottom: 16rpx;
  margin-bottom: 32rpx;
}

.sub-tab {
  font-size: 28rpx;
  font-weight: 500;
  color: #9ca3af;
  padding-bottom: 16rpx;
  position: relative;
  margin-right: 48rpx;
}

.sub-tab-active { color: #111827; }

.sub-tab-line {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background-color: #111827;
  border-radius: 2rpx;
}

.items-grid-2 {
  display: flex;
  flex-wrap: wrap;
}

.wishlist-item {
  width: calc(50% - 12rpx);
  margin: 0 12rpx 24rpx 0;
  position: relative;
  height: 360rpx;
  border-radius: 24rpx;
  overflow: hidden;
  opacity: 0.8;
  box-sizing: border-box;
}

.wishlist-selected {
  border: 4rpx solid #a855f7;
  opacity: 1;
  transform: scale(0.95);
}

.wishlist-img { width: 100%; height: 100%; }

.wishlist-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background-color: rgba(255,255,255,0.9);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.empty-wishlist {
  width: 100%;
  padding: 64rpx 0;
  text-align: center;
  border: 2px dashed #f3f4f6;
  border-radius: 24rpx;
  color: #9ca3af;
  font-size: 28rpx;
}

/* External Form */
.form-row { margin-bottom: 24rpx; }
.form-label { font-size: 24rpx; font-weight: 700; color: #6b7280; margin-bottom: 12rpx; display: block; }

.link-input-wrap { position: relative; }
.link-emoji {
  position: absolute; left: 24rpx; top: 50%; transform: translateY(-50%);
  font-size: 28rpx; z-index: 1;
}

.link-input {
  width: 100%; background-color: #ffffff; border: 1px solid #e5e7eb;
  border-radius: 24rpx; padding: 24rpx 24rpx 24rpx 80rpx; font-size: 28rpx; box-sizing: border-box;
}

.or-divider {
  display: flex; align-items: center; font-size: 24rpx; color: #9ca3af; margin-bottom: 24rpx;
}
.or-line { flex: 1; height: 1px; background-color: #f3f4f6; }
.or-divider text { padding: 0 16rpx; }

.upload-box { border: 2px dashed #e5e7eb; border-radius: 24rpx; padding: 32rpx; }
.upload-placeholder {
  display: flex; flex-direction: column; align-items: center; padding: 48rpx 0; color: #9ca3af; font-size: 24rpx;
}
.upload-circle {
  width: 96rpx; height: 96rpx; border-radius: 50%; background-color: #f3f4f6;
  display: flex; align-items: center; justify-content: center; margin-bottom: 16rpx;
}
.upload-emoji { font-size: 48rpx; }
.upload-preview { width: 100%; height: 300rpx; border-radius: 16rpx; background-color: #f3f4f6; }

/* Generate Button */
.gen-btn-wrap { position: fixed; bottom: 96rpx; left: 48rpx; right: 48rpx; z-index: 20; }
.gen-btn {
  width: 100%; padding: 32rpx 0; border-radius: 32rpx; background-color: #111827;
  color: #ffffff; font-weight: 700; font-size: 28rpx;
  box-shadow: 0 40rpx 50rpx -20rpx rgba(156,163,175,0.5);
  display: flex; align-items: center; justify-content: center;
}
.gen-btn-emoji { margin-right: 16rpx; font-size: 32rpx; }
.gen-btn-disabled { background-color: #d1d5db; color: #6b7280; box-shadow: none; }

/* Generating */
.generating-view {
  height: 100%; display: flex; flex-direction: column;
  align-items: center; justify-content: center; padding: 48rpx; padding-bottom: 256rpx;
}
.gen-spinner { position: relative; width: 192rpx; height: 192rpx; margin-bottom: 64rpx; }
.gen-ring {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  border: 8rpx solid #f3f4f6; border-radius: 50%;
  border-top-color: #a855f7;
  animation: spin 1s linear infinite;
}
.gen-sparkle-emoji {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
  font-size: 56rpx;
}
@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

.gen-title { font-size: 40rpx; font-weight: 700; color: #1f2937; text-align: center; margin-bottom: 16rpx; display: block; }
.gen-text { font-size: 28rpx; color: #6b7280; text-align: center; max-width: 400rpx; display: block; }

/* Result */
.result-view { height: 100%; display: flex; flex-direction: column; background-color: #f9fafb; margin: 0 -48rpx; }

/* 人形剪影预览 */
.silhouette-wrap {
  height: 40%;
  background: linear-gradient(180deg, #ffffff 0%, #f3f4f6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
  box-sizing: border-box;
}
.silhouette {
  position: relative;
  width: 280rpx;
  height: 100%;
  max-height: 460rpx;
}
.s-head {
  position: absolute;
  top: 0; left: 50%;
  transform: translateX(-50%);
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  background: #e5e7eb;
}
.s-neck {
  position: absolute;
  top: 72rpx; left: 50%;
  transform: translateX(-50%);
  width: 32rpx; height: 32rpx;
  background: #e5e7eb;
}
.s-body {
  position: absolute;
  top: 96rpx; left: 50%;
  transform: translateX(-50%);
  width: 200rpx; height: 340rpx;
  border-radius: 60rpx 60rpx 40rpx 40rpx;
  background: #eef0f3;
}
/* 衣物叠加层：按部位定位到人形对应区域 */
.p-top, .p-outer, .p-bottom, .p-dress, .p-shoes {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}
.p-top {
  top: 96rpx;
  width: 240rpx; height: 200rpx;
}
.p-outer {
  top: 90rpx;
  width: 260rpx; height: 230rpx;
}
.p-dress {
  top: 96rpx;
  width: 260rpx; height: 360rpx;
}
.p-bottom {
  top: 280rpx;
  width: 230rpx; height: 180rpx;
}
.p-shoes {
  top: 420rpx;
  width: 200rpx; height: 60rpx;
}

.result-images {
  height: 45%; background-color: #ffffff; position: relative; overflow: hidden;
  display: flex; flex-wrap: wrap; padding: 64rpx; align-content: center;
}
.result-main { width: 100%; height: 300rpx; }
.result-img-wrap {
  width: calc(50% - 16rpx); margin: 0 16rpx 0 0; height: 200rpx;
  border-radius: 24rpx; overflow: hidden; background-color: #f9fafb; position: relative;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.05); box-sizing: border-box;
}
.result-img { width: 100%; height: 100%; }
.result-gradient { height: 192rpx; background: linear-gradient(to top, #f9fafb, transparent); margin-top: -48rpx; }

.result-tag { position: absolute; padding: 8rpx 16rpx; border-radius: 8rpx; box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.1); }
.result-tag text { font-size: 20rpx; font-weight: 700; color: #ffffff; }
.new-tag { top: 16rpx; right: 16rpx; background-color: #a855f7; }
.lock-tag { top: 16rpx; left: 16rpx; background-color: rgba(17, 24, 39, 0.8); }

/* Result Card */
.result-card {
  flex: 1; background-color: #ffffff; border-radius: 48rpx 48rpx 0 0;
  margin-top: -48rpx; position: relative; z-index: 10;
  padding: 64rpx 48rpx 192rpx; box-shadow: 0 -16rpx 80rpx rgba(0,0,0,0.05); overflow-y: auto;
}
.result-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 32rpx; }
.result-title { font-size: 40rpx; font-weight: 700; color: #111827; display: block; }
.result-score { margin-top: 8rpx; }
.result-score text { background-color: #dcfce7; color: #15803d; font-size: 24rpx; padding: 4rpx 16rpx; border-radius: 9999rpx; font-weight: 700; }
.apply-btn { padding: 16rpx 32rpx; border-radius: 24rpx; background-color: #111827; font-size: 24rpx; font-weight: 700; color: #ffffff; box-shadow: 0 20rpx 30rpx -10rpx rgba(0,0,0,0.2); }
.apply-btn.applied { background-color: #dcfce7; color: #16a34a; }
.result-reasoning { font-size: 28rpx; color: #4b5563; line-height: 1.625; margin-bottom: 48rpx; display: block; }
.result-actions { display: flex; align-items: center; justify-content: space-between; }
.retry-btn { flex: 1; padding: 24rpx 0; border: 1px solid #e5e7eb; border-radius: 24rpx; text-align: center; font-size: 28rpx; color: #4b5563; margin-right: 32rpx; }
.thumbsup-btn { padding: 24rpx; background-color: #111827; border-radius: 24rpx; font-size: 36rpx; box-shadow: 0 20rpx 30rpx -10rpx rgba(0,0,0,0.2); }

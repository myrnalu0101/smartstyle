/* ========================================
   认证页面样式 — 精简版
   ======================================== */

.page-auth {
  min-height: 100vh;
  background: linear-gradient(to bottom, #f0fdf4, #ffffff);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
}

/* Logo */
.logo-section {
  margin-bottom: 64rpx;
  text-align: center;
}

.logo-icon {
  width: 128rpx;
  height: 128rpx;
  background: linear-gradient(to bottom right, #22c55e, #a855f7);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
  box-shadow: 0 20rpx 30rpx -10rpx rgba(34, 197, 94, 0.3);
}

.logo-emoji {
  font-size: 56rpx;
}

.logo-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
}

.logo-subtitle {
  font-size: 28rpx;
  color: #6b7280;
  margin-top: 8rpx;
  display: block;
}

/* Auth Card */
.auth-card {
  width: 100%;
  max-width: 640rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 40rpx 50rpx -20rpx rgba(0, 0, 0, 0.1);
  border: 1px solid #f3f4f6;
  padding: 48rpx;
}

/* Tab Switch */
.tab-switch {
  display: flex;
  background-color: #f3f4f6;
  padding: 4rpx;
  border-radius: 24rpx;
  margin-bottom: 48rpx;
}

.tab-item {
  flex: 1;
  padding: 16rpx 0;
  border-radius: 20rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #6b7280;
  transition: all 0.2s ease;
}

.tab-active {
  background-color: #ffffff;
  color: #111827;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

/* Error */
.error-msg {
  background-color: #fef2f2;
  color: #dc2626;
  font-size: 24rpx;
  padding: 10rpx 32rpx;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  text-align: center;
}

/* Form */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #6b7280;
  margin-bottom: 8rpx;
  display: block;
}

.form-input {
  width: 100%;
  background-color: #f9fafb;
  border: 1px solid #e5e7eb;
  border-radius: 24rpx;
  padding: 30rpx 32rpx;
  font-size: 30rpx;
  line-height: 1.5;
  min-height: 96rpx;
  box-sizing: border-box;
}

/* Submit Button */
.submit-btn {
  width: 100%;
  background-color: #111827;
  color: #ffffff;
  font-weight: 700;
  font-size: 28rpx;
  padding: 28rpx 0;
  border-radius: 32rpx;
  box-shadow: 0 20rpx 30rpx -10rpx rgba(17, 24, 39, 0.2);
  border: none;
  margin-top: 16rpx;
}

.submit-btn[disabled] {
  opacity: 0.5;
}

.submit-btn:active {
  transform: scale(0.95);
}
